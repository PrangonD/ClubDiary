//backend
// Feature 3 (Sprint 2) - Role-Based Access Control support (role assignment/admin control) - Owner: MUNEEM
const express = require("express");
const User = require("../models/User");
const { protect, allowRoles } = require("../middleware/authMiddleware");
const { isValidObjectId } = require("../utils/validators");

const router = express.Router();

router.get("/", protect, allowRoles("Admin", "President"), async (_req, res) => {
  const users = await User.find().select("name email role").sort({ name: 1 });
  res.json(users);
});

router.patch("/:id/role", protect, allowRoles("Admin"), async (req, res) => {
  if (!isValidObjectId(req.params.id)) {
    return res.status(400).json({ message: "Invalid user id" });
  }
  const allowedRoles = ["Admin", "President", "Student"];
  const role = String(req.body.role || "");
  if (!allowedRoles.includes(role)) {
    return res.status(400).json({ message: "Invalid role value" });
  }

  const user = await User.findById(req.params.id);
  if (!user) return res.status(404).json({ message: "User not found" });

  user.role = role;
  await user.save();

  res.json({
    message: "Role updated",
    user: { id: user._id, name: user.name, email: user.email, role: user.role }
  });
});

module.exports = router;




//frontend
// Feature 3 (Sprint 2) - Role-Based Access Control in frontend routes - Owner: MUNEEM
import { Navigate } from "react-router-dom";
import { useAuth } from "../context/AuthContext";

export default function ProtectedRoute({ children, roles = [] }) {
  const { auth } = useAuth();
  if (!auth.token) return <Navigate to="/login" replace />;
  if (roles.length > 0 && !roles.includes(auth.user?.role)) {
    return (
      <div className="card denied-message">
        <h2>Access restricted</h2>
        <p>Your role does not include this area. Contact an admin if you need access.</p>
      </div>
    );
  }
  return children;
}



//admin panel page
// Feature 9/14/16/17 + role operations (Sprint 3/4) - Admin controls UI - Owners: Prapty, PRANGON, MUNEEM
import { useEffect, useState } from "react";
import { API } from "../api";
import { useAuth } from "../context/AuthContext";
import { confirmAlert, errorAlert, successAlert } from "../utils/alerts";

export default function AdminPanelPage() {
  const { auth } = useAuth();
  const [requests, setRequests] = useState([]);
  const [requestPage, setRequestPage] = useState(1);
  const [requestTotalPages, setRequestTotalPages] = useState(1);
  const [requestTotal, setRequestTotal] = useState(0);
  const [requestStatus, setRequestStatus] = useState("pending");
  const [requestClubId, setRequestClubId] = useState("");
  const [requestSearch, setRequestSearch] = useState("");
  const [clubs, setClubs] = useState([]);
  const [users, setUsers] = useState([]);
  const [expense, setExpense] = useState({ clubId: "", title: "", amount: "", receiptUrl: "", receipt: null });
  const [payment, setPayment] = useState({ userId: "", clubId: "", amount: "", billingPeriod: "" });
  const [post, setPost] = useState({ title: "", content: "", clubId: "" });
  const [roleForm, setRoleForm] = useState({ userId: "", role: "Student" });
  const [error, setError] = useState("");

  const load = async (nextRequestPage = requestPage) => {
    setError("");
    try {
      const reqQuery = new URLSearchParams({
        page: String(nextRequestPage),
        limit: "12",
        status: requestStatus
      });
      if (requestClubId) reqQuery.set("clubId", requestClubId);
      if (requestSearch.trim()) reqQuery.set("q", requestSearch.trim());
      const [reqRes, clubRes, usersRes] = await Promise.all([
        API.get(`/memberships/requests?${reqQuery.toString()}`),
        API.get("/clubs?page=1&limit=100"),
        API.get("/users")
      ]);
      const clubItems = clubRes.data.items || [];
      setRequests(reqRes.data.items || []);
      setRequestPage(reqRes.data.page || 1);
      setRequestTotalPages(reqRes.data.totalPages || 1);
      setRequestTotal(reqRes.data.total || 0);
      setClubs(clubItems);
      setUsers(usersRes.data || []);
      if (clubItems[0]) {
        const firstClub = clubItems[0]._id;
        setExpense((s) => ({ ...s, clubId: s.clubId || firstClub }));
        setPost((s) => ({ ...s, clubId: s.clubId || firstClub }));
        setPayment((s) => ({ ...s, clubId: s.clubId || firstClub }));
      }
      if (usersRes.data?.[0]) {
        setPayment((s) => ({ ...s, userId: s.userId || usersRes.data[0]._id }));
        setRoleForm((s) => ({ ...s, userId: s.userId || usersRes.data[0]._id }));
      }
    } catch (err) {
      setError(err.response?.data?.message || "Failed loading admin data");
    }
  };

  useEffect(() => {
    load(1);
  }, [requestStatus, requestClubId, requestSearch]);

  const updateStatus = async (id, status) => {
    try {
      await API.put(`/memberships/${id}/status`, { status });
      successAlert(`Membership ${status}`);
      load(requestPage);
    } catch (err) {
      errorAlert("Could not update membership", err.response?.data?.message || "");
    }
  };

  const createExpense = async (e) => {
    e.preventDefault();
    setError("");
    const fd = new FormData();
    fd.append("clubId", expense.clubId);
    fd.append("title", expense.title);
    fd.append("amount", expense.amount);
    fd.append("receiptUrl", expense.receiptUrl);
    if (expense.receipt) fd.append("receipt", expense.receipt);

    try {
      await API.post("/expenses", fd);
      setExpense({ ...expense, title: "", amount: "", receiptUrl: "", receipt: null });
      successAlert("Expense added");
    } catch (err) {
      errorAlert("Could not create expense", err.response?.data?.message || "");
    }
  };

  const addPayment = async (e) => {
    e.preventDefault();
    setError("");
    try {
      await API.post("/payments", payment);
      successAlert("Payment saved");
      load(requestPage);
    } catch (err) {
      errorAlert("Could not save payment", err.response?.data?.message || "");
    }
  };

  const createPost = async (e) => {
    e.preventDefault();
    setError("");
    try {
      await API.post("/posts", post);
      setPost({ ...post, title: "", content: "" });
      successAlert("News post created");
    } catch (err) {
      errorAlert("Could not create post", err.response?.data?.message || "");
    }
  };

  const updateUserRole = async (e) => {
    e.preventDefault();
    setError("");
    try {
      await API.patch(`/users/${roleForm.userId}/role`, { role: roleForm.role });
      successAlert("Role updated");
      load(requestPage);
    } catch (err) {
      errorAlert("Could not update role", err.response?.data?.message || "");
    }
  };

  return (
    <div className="card page">
      <div className="page-hero">
        <h2 className="page-title">Admin Panel</h2>
        <p className="page-subtitle">Manage memberships, finance operations, publishing, and user permissions.</p>
      </div>
      {error && <p className="error">{error}</p>}

      <div className="section-card">
      <h3>Member Management</h3>
      <div className="filters request-toolbar">
        <select value={requestStatus} onChange={(e) => setRequestStatus(e.target.value)}>
          <option value="pending">Pending</option>
          <option value="approved">Approved</option>
          <option value="rejected">Rejected</option>
        </select>
        <select value={requestClubId} onChange={(e) => setRequestClubId(e.target.value)}>
          <option value="">All clubs</option>
          {clubs.map((club) => (
            <option key={club._id} value={club._id}>
              {club.name}
            </option>
          ))}
        </select>
        <input
          placeholder="Search by user, email, or club"
          value={requestSearch}
          onChange={(e) => setRequestSearch(e.target.value)}
        />
        <button type="button" className="compact-btn compact-btn-primary" onClick={() => load(1)}>
          Apply
        </button>
      </div>
      <p className="meta-text">{requestTotal} total requests</p>
      {requests.length === 0 && <p className="empty-state">No requests found for current filters.</p>}
      {requests.map((request) => (
        <div key={request._id} className="row request-row">
          <span className="request-meta">
            <strong>{request.user?.name}</strong> {"->"} {request.club?.name}
          </span>
          <div className="row-actions request-actions">
            {request.status !== "approved" && (
              <button type="button" className="compact-btn compact-btn-success" onClick={() => updateStatus(request._id, "approved")}>
                Approve
              </button>
            )}
            {request.status !== "rejected" && (
              <button type="button" className="compact-btn compact-btn-muted" onClick={() => updateStatus(request._id, "rejected")}>
                Reject
              </button>
            )}
            <button
              type="button"
              className="compact-btn compact-btn-danger"
              onClick={async () => {
                const ok = await confirmAlert("Remove membership?", "This member relation will be deleted.", "Remove");
                if (!ok) return;
                try {
                  await API.delete(`/memberships/${request._id}`);
                  successAlert("Membership removed");
                  load(requestPage);
                } catch (err) {
                  errorAlert("Could not remove membership", err.response?.data?.message || "");
                }
              }}
            >
              Remove
            </button>
          </div>
        </div>
      ))}
      <div className="pager">
        <button type="button" disabled={requestPage <= 1} onClick={() => load(requestPage - 1)}>
          Prev
        </button>
        <span>
          Page {requestPage} / {requestTotalPages}
        </span>
        <button type="button" disabled={requestPage >= requestTotalPages} onClick={() => load(requestPage + 1)}>
          Next
        </button>
      </div>
      </div>

      <div className="admin-grid">
      {auth.user?.role === "Admin" && (
        <form className="section-card stack-md" onSubmit={updateUserRole}>
          <h3>Role Assignment (Admin only)</h3>
          <select value={roleForm.userId} onChange={(e) => setRoleForm({ ...roleForm, userId: e.target.value })} required>
            {users.map((u) => (
              <option key={u._id} value={u._id}>
                {u.name} ({u.role})
              </option>
            ))}
          </select>
          <select value={roleForm.role} onChange={(e) => setRoleForm({ ...roleForm, role: e.target.value })} required>
            <option value="Student">Student</option>
            <option value="President">President</option>
            <option value="Admin">Admin</option>
          </select>
          <button type="submit">Update Role</button>
        </form>
      )}

      <form className="section-card stack-md" onSubmit={createExpense}>
        <h3>Expense Management</h3>
        <select value={expense.clubId} onChange={(e) => setExpense({ ...expense, clubId: e.target.value })}>
          {clubs.map((club) => (
            <option key={club._id} value={club._id}>
              {club.name}
            </option>
          ))}
        </select>
        <input placeholder="Expense title" value={expense.title} onChange={(e) => setExpense({ ...expense, title: e.target.value })} required />
        <input type="number" step="0.01" min="0.01" placeholder="Amount" value={expense.amount} onChange={(e) => setExpense({ ...expense, amount: e.target.value })} required />
        <input placeholder="Receipt URL (optional)" value={expense.receiptUrl} onChange={(e) => setExpense({ ...expense, receiptUrl: e.target.value })} />
        <label className="drop-zone">
          <span className="meta-text">Drag and drop receipt or click to upload</span>
          <input type="file" accept="image/*,.pdf" onChange={(e) => setExpense({ ...expense, receipt: e.target.files?.[0] || null })} />
        </label>
        <button type="submit">Add Expense</button>
      </form>

      <form className="section-card stack-md" onSubmit={addPayment}>
        <h3>Membership Fee Tracking</h3>
        <select value={payment.clubId} onChange={(e) => setPayment({ ...payment, clubId: e.target.value })} required>
          {clubs.map((club) => (
            <option key={club._id} value={club._id}>
              {club.name}
            </option>
          ))}
        </select>
        <select value={payment.userId} onChange={(e) => setPayment({ ...payment, userId: e.target.value })} required>
          {users.map((u) => (
            <option key={u._id} value={u._id}>
              {u.name} ({u.email})
            </option>
          ))}
        </select>
        <input type="month" value={payment.billingPeriod} onChange={(e) => setPayment({ ...payment, billingPeriod: e.target.value })} />
        <input type="number" step="0.01" min="0.01" placeholder="Fee amount" value={payment.amount} onChange={(e) => setPayment({ ...payment, amount: e.target.value })} required />
        <button type="submit">Save Fee Payment</button>
      </form>

      <form className="section-card stack-md" onSubmit={createPost}>
        <h3>News / Blog Section</h3>
        <select value={post.clubId} onChange={(e) => setPost({ ...post, clubId: e.target.value })}>
          {clubs.map((club) => (
            <option key={club._id} value={club._id}>
              {club.name}
            </option>
          ))}
        </select>
        <input placeholder="Post title" value={post.title} onChange={(e) => setPost({ ...post, title: e.target.value })} required />
        <textarea placeholder="Post content" value={post.content} onChange={(e) => setPost({ ...post, content: e.target.value })} required />
        <button type="submit">Publish Post</button>
      </form>
      </div>
    </div>
  );
}

